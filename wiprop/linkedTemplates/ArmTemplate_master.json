{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "wiprop"
		},
		"SNOW_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'SNOW'"
		},
		"SNOW_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "TRAININGDB"
		},
		"SNOW_properties_typeProperties_role": {
			"type": "string",
			"defaultValue": "accountadmin"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "wiprop_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"SNOW_password": {
						"value": "[parameters('SNOW_password')]"
					},
					"SNOW_properties_typeProperties_database": {
						"value": "[parameters('SNOW_properties_typeProperties_database')]"
					},
					"SNOW_properties_typeProperties_role": {
						"value": "[parameters('SNOW_properties_typeProperties_role')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}