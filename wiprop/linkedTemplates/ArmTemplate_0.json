						"     insertable:true,",
						"     updateable:false,",
						"     upsertable:false,",
						"     format: 'table',",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     mapColumn(",
						"          EMPID,",
						"          ENAME,",
						"          LOCATION,",
						"          DEPTNO",
						"     )) ~> TgtEmp"
					]
				}
