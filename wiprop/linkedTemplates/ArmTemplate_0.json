			"apiVersion": "2018-06-01",
			"properties": {
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "EmpSrc1",
								"type": "DatasetReference"
							},
							"name": "EmpSrc1"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "SurgtKeyTransf",
								"type": "DatasetReference"
							},
							"name": "SurgtKeyTransform"
						}
					],
					"transformations": [
						{
							"name": "surrogateKey1"
						}
					],
					"scriptLines": [
						"source(output(",
						"          EMPID as decimal(38,0),",
						"          ENAME as string,",
						"          SAL as decimal(38,0),",
						"          LOCATION as string,",
						"          DEPTNO as decimal(38,0)",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     format: 'table') ~> EmpSrc1",
						"EmpSrc1 keyGenerate(output(emp_key as long),",
						"     startAt: 1L,",
						"     stepValue: 1L) ~> surrogateKey1",
						"surrogateKey1 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     deletable:false,",
						"     insertable:true,",
						"     updateable:false,",
						"     upsertable:false,",
						"     recreate:true,",
						"     format: 'table',",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     stageInsert: true) ~> SurgtKeyTransform"
					]
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/EmpSrc1')]",
				"[concat(variables('factoryId'), '/datasets/SurgtKeyTransf')]"
			]
		},
